  <diagram id="ELI-API-Process-Flow" name="ELI API Process Flow">
    <mxGraphModel dx="371" dy="394" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" background="#6E6E6E" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="ELI API - Typical Process Flow" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="450" y="20" width="270" height="30" as="geometry" />
        </mxCell>
        <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="540" y="70" width="90" height="40" as="geometry" />
        </mxCell>
        <mxCell id="step1" value="1. Calculate New Offers&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;POST /v3/vorgaenge/{case-id}/ergebnisliste&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="480" y="140" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="2. Get Offer Details&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;GET /v3/vorgaenge/{case-id}/ergebnisliste/{id}/{num}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="480" y="220" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="3. Get Additional Details&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;GET .../meldungen, .../unterlagen, .../zahlungsplaene&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="480" y="300" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step4" value="4. Save Specific Offer&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;POST .../merken&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="480" y="380" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step5" value="5. Create Finanzierungsvorschlag&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;POST .../finanzierungsvorschlagsdokumente&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="770" y="379.5" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step6" value="6. Get Offer Documents&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;GET .../angebotsdokumente&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="770" y="459.5" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step7" value="7. Get Condition Information&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;GET .../konditionsanpassung&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="200" y="380" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step8" value="8. Change/Set Condition&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;POST .../konditionsanpassung&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="200" y="459.5" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step9" value="9. Set as Recommended&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;PATCH .../gemerkteangebote/{num}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="480" y="530" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step10" value="10. Validate Offer&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;POST .../pruefen&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="480" y="600" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step11" value="11. Accept Offer&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;POST .../annehmen&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="480" y="670" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="end" value="End&lt;br&gt;Offer Accepted" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="540" y="750" width="90" height="50" as="geometry" />
        </mxCell>
